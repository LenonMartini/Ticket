generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
 
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum TicketStatus {
  PENDING       // aguardando na fila, nenhum agente assumiu
  BOT_ACTIVE    // bot está conduzindo o atendimento
  OPEN          // agente assumiu
  WAITING       // aguardando resposta do cliente
  TRANSFERRED   // foi transferido para outro setor/agente
  RESOLVED      // marcado como resolvido
  CLOSED        // encerrado definitivamente
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketChannel {
  WHATSAPP
  EMAIL
  MANUAL
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT_CARD
  SYSTEM        // mensagens internas de sistema (ex: "ticket assumido por X")
  NOTE          // nota interna (não chega ao cliente)
}

enum SenderType {
  CONTACT   // mensagem do cliente
  AGENT     // mensagem do agente
  BOT       // mensagem enviada pelo bot/n8n
  SYSTEM    // evento de sistema
}

enum StockMovementType {
  IN          // entrada manual
  OUT         // saída manual
  IN_NFE      // entrada por NF-e
  OUT_SALE    // saída por venda
  ADJUSTMENT  // ajuste de inventário
  TRANSFER    // transferência entre lojas
}

enum NfeStatus {
  PENDING    // importada, aguardando processamento
  PROCESSED  // itens processados e estoque atualizado
  ERROR      // erro no processamento
  CANCELLED  // NF-e cancelada
}

enum BotSessionStatus {
  ACTIVE      // bot conduzindo ativamente
  WAITING     // aguardando resposta do cliente
  ESCALATED   // escalonado para agente humano
  FINISHED    // fluxo concluído sem escalonamento
  ABANDONED   // cliente não respondeu (timeout)
}

enum N8nTriggerType {
  WEBHOOK           // chamada HTTP externa
  MESSAGE_RECEIVED  // mensagem recebida na instância
  TICKET_CREATED    // ticket criado
  TICKET_CLOSED     // ticket encerrado
  SCHEDULED         // agendado (cron)
}

enum N8nExecutionStatus {
  RUNNING
  SUCCESS
  ERROR
  TIMEOUT
}

enum EvolutionStatus {
  DISCONNECTED
  QR_PENDING
  CONNECTING
  CONNECTED
}

enum TicketEventType {
  CREATED
  BOT_STARTED
  BOT_ESCALATED
  BOT_FINISHED
  ASSUMED
  TRANSFERRED
  RESOLVED
  CLOSED
  REOPENED
  PRIORITY_CHANGED
  TAG_ADDED
  TAG_REMOVED
  NOTE_ADDED
}

// ─────────────────────────────────────────────────────────────
// TENANTS
// Raiz de isolamento de dados — tudo pertence a um tenant
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(BASIC)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings           TenantSettings?
  users              User[]
  stores             Store[]
  departments        Department[]
  roles              Role[]
  contacts           Contact[]
  evolutionInstances EvolutionInstance[]
  tickets            Ticket[]
  tags               Tag[]
  products           Product[]
  productCategories  ProductCategory[]
  nfeImports         NfeImport[]
  n8nWorkflows       N8nWorkflow[]

  @@map("tenants")
}

model TenantSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Mensagens do bot
  welcomeMessage   String @default("Olá! Como podemos te ajudar? 😊")
  menuMessage      String @default("Escolha uma opção:")
  transferMessage  String @default("Aguarde, estamos transferindo seu atendimento...")
  closingMessage   String @default("Atendimento encerrado. Obrigado! 😊")
  offlineMessage   String @default("No momento estamos fora do horário de atendimento.")

  // Horário de atendimento
  businessHoursEnabled Boolean @default(false)
  businessHoursStart   String  @default("08:00")
  businessHoursEnd     String  @default("18:00")
  businessDays         Int[]   @default([1, 2, 3, 4, 5]) // 0=Dom … 6=Sáb

  // Comportamento do ticket
  inactivityTimeout    Int @default(24) // horas para fechar ticket inativo
  maxTicketsPerAgent   Int @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_settings")
}

// ─────────────────────────────────────────────────────────────
// USERS
// Credencial de acesso — um user pode ser agente em N tenants
// ─────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name         String
  email        String
  passwordHash String
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastLogin    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userRoles       UserRole[]
  tickets         Ticket[]         @relation("AssignedTickets")
  messages        Message[]
  ticketEvents    TicketEvent[]
  stockMovements  StockMovement[]
  nfeImports      NfeImport[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// STORES
// Uma loja/unidade dentro de um tenant
// ─────────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  settings  Json?    // configurações extras livres
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments        Department[]
  evolutionInstances EvolutionInstance[]
  tickets            Ticket[]
  stocks             Stock[]
  stockMovements     StockMovement[]
  nfeImports         NfeImport[]

  @@index([tenantId])
  @@map("stores")
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS
// Setores de atendimento dentro de uma loja
// ─────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String   @default("#6366f1")
  menuOption  Int?     // posição no menu do bot
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]
  tickets   Ticket[]

  @@index([tenantId])
  @@index([storeId])
  @@map("departments")
}

// ─────────────────────────────────────────────────────────────
// RBAC — PERMISSIONS
// Permissões atômicas globais (não pertencem a tenant)
// ─────────────────────────────────────────────────────────────

model Permission {
  id          String @id @default(uuid())
  key         String @unique // ex: "tickets:close"
  resource    String          // ex: "tickets"
  action      String          // ex: "close"
  description String?

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────
// RBAC — ROLES
// ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isSystem    Boolean  @default(false) // roles protegidas (não podem ser deletadas)
  isDefault   Boolean  @default(false) // role atribuída automaticamente a novos usuários
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// RBAC — USER_ROLES
// Vínculo contextual: user tem role X na loja Y, departamento Z
// ─────────────────────────────────────────────────────────────

model UserRole {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  storeId      String?
  store        Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())

  @@unique([userId, roleId, storeId, departmentId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// CONTACTS
// Clientes que entram em contato — identificados pelo telefone
// ─────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  phone     String
  name      String?
  email     String?
  avatarUrl String?
  isBlocked Boolean  @default(false)
  extraData Json?    // campos customizados livres
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets     Ticket[]
  botSessions BotSession[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// EVOLUTION INSTANCES
// Cada número de WhatsApp conectado ao tenant
// Um tenant pode ter N instâncias (N números)
// ─────────────────────────────────────────────────────────────

model EvolutionInstance {
  id           String          @id @default(uuid())
  tenantId     String
  tenant       Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String?
  store        Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)

  instanceName String          // nome da instância na Evolution API
  phoneNumber  String?         // número após conexão
  apiKey       String
  webhookUrl   String?
  status       EvolutionStatus @default(DISCONNECTED)
  qrCode       String?         @db.Text
  connectedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tickets      Ticket[]
  botSessions  BotSession[]
  n8nWorkflows N8nWorkflow[]

  @@unique([tenantId, instanceName])
  @@index([tenantId])
  @@map("evolution_instances")
}

// ─────────────────────────────────────────────────────────────
// N8N WORKFLOWS
// Workflows do N8N vinculados a uma instância Evolution
// ─────────────────────────────────────────────────────────────

model N8nWorkflow {
  id                   String         @id @default(uuid())
  tenantId             String
  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evolutionInstanceId  String?
  evolutionInstance    EvolutionInstance? @relation(fields: [evolutionInstanceId], references: [id], onDelete: SetNull)

  n8nWorkflowId        String         // ID do workflow no N8N
  name                 String
  description          String?
  triggerType          N8nTriggerType @default(MESSAGE_RECEIVED)
  triggerEvent         String?        // evento específico que dispara (ex: keyword, status)
  isActive             Boolean        @default(true)
  settings             Json?          // configurações extras (timeout, retry, etc.)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  botSessions  BotSession[]
  executions   N8nExecution[]

  @@unique([tenantId, n8nWorkflowId])
  @@index([tenantId])
  @@map("n8n_workflows")
}

// ─────────────────────────────────────────────────────────────
// BOT SESSIONS
// Estado da sessão do bot por contato/instância
// Guarda em qual etapa do fluxo o cliente está
// ─────────────────────────────────────────────────────────────

model BotSession {
  id                  String           @id @default(uuid())
  tenantId            String
  contactId           String
  contact             Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
  evolutionInstanceId String
  evolutionInstance   EvolutionInstance @relation(fields: [evolutionInstanceId], references: [id], onDelete: Cascade)
  n8nWorkflowId       String?
  n8nWorkflow         N8nWorkflow?     @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)
  ticketId            String?          @unique // criado ao escalonar para humano
  ticket              Ticket?          @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  status             BotSessionStatus @default(ACTIVE)
  currentStep        String?          // nó atual no fluxo do N8N
  context            Json?            // variáveis coletadas (nome, CPF, opção escolhida…)
  interactionsCount  Int              @default(0)
  startedAt          DateTime         @default(now())
  lastInteractionAt  DateTime         @default(now())
  finishedAt         DateTime?

  executions N8nExecution[]

  @@index([tenantId])
  @@index([contactId])
  @@index([evolutionInstanceId])
  @@map("bot_sessions")
}

// ─────────────────────────────────────────────────────────────
// N8N EXECUTIONS
// Histórico de cada execução de workflow
// ─────────────────────────────────────────────────────────────

model N8nExecution {
  id              String             @id @default(uuid())
  n8nWorkflowId   String
  n8nWorkflow     N8nWorkflow        @relation(fields: [n8nWorkflowId], references: [id], onDelete: Cascade)
  botSessionId    String?
  botSession      BotSession?        @relation(fields: [botSessionId], references: [id], onDelete: SetNull)
  ticketId        String?

  n8nExecutionId  String?            // ID da execução no N8N (para rastreamento)
  status          N8nExecutionStatus @default(RUNNING)
  triggerEvent    String?
  inputData       Json?
  outputData      Json?
  errorMessage    String?            @db.Text
  durationMs      Int?
  startedAt       DateTime           @default(now())
  finishedAt      DateTime?

  @@index([n8nWorkflowId])
  @@index([botSessionId])
  @@map("n8n_executions")
}

// ─────────────────────────────────────────────────────────────
// TICKETS
// ─────────────────────────────────────────────────────────────

model Ticket {
  id          String        @id @default(uuid())
  tenantId    String
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId     String?
  store       Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  departmentId String?
  department  Department?   @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id])
  assignedTo  String?
  assignedUser User?        @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  evolutionInstanceId String?
  evolutionInstance   EvolutionInstance? @relation(fields: [evolutionInstanceId], references: [id], onDelete: SetNull)

  protocol      String        // número de protocolo gerado
  channel       TicketChannel @default(WHATSAPP)
  status        TicketStatus  @default(PENDING)
  priority      Priority      @default(NORMAL)
  subject       String?
  isBotActive   Boolean       @default(false)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  messages   Message[]
  events     TicketEvent[]
  tags       TicketTag[]
  botSession BotSession?   // sessão de bot que originou/está vinculada

  @@unique([tenantId, protocol])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, departmentId])
  @@map("tickets")
}

// ─────────────────────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────────────────────

model Message {
  id             String      @id @default(uuid())
  ticketId       String
  ticket         Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUserId   String?
  senderUser     User?       @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  senderType     SenderType  @default(CONTACT)
  content        String?     @db.Text
  type           MessageType @default(TEXT)
  mediaUrl       String?
  mediaName      String?
  evolutionMsgId String?     @unique // ID da mensagem na Evolution API (evita duplicatas)
  isRead         Boolean     @default(false)
  sentAt         DateTime    @default(now())

  @@index([ticketId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// TICKET EVENTS (timeline de auditoria)
// ─────────────────────────────────────────────────────────────

model TicketEvent {
  id          String          @id @default(uuid())
  ticketId    String
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  type        TicketEventType
  description String?
  changes     Json?           // snapshot do que mudou { from, to }
  createdAt   DateTime        @default(now())

  @@index([ticketId])
  @@map("ticket_events")
}

// ─────────────────────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────────────────────

model Tag {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#6366f1")

  ticketTags TicketTag[]

  @@unique([tenantId, name])
  @@map("tags")
}

model TicketTag {
  ticketId String
  tagId    String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT CATEGORIES
// Categorias hierárquicas (categoria pai → subcategorias)
// ─────────────────────────────────────────────────────────────

model ProductCategory {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ProductCategory?  @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)

  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  children ProductCategory[] @relation("CategoryChildren")
  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sku         String
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @db.Decimal(12, 2) @default(0)
  unit        String   @default("un") // un, kg, cx, l…
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stocks         Stock[]
  stockMovements StockMovement[]
  nfeItems       NfeItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// STOCK
// Saldo atual por produto + loja
// ─────────────────────────────────────────────────────────────

model Stock {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  quantity    Decimal @db.Decimal(12, 3) @default(0)
  minQuantity Decimal @db.Decimal(12, 3) @default(0) // alerta de estoque mínimo
  maxQuantity Decimal @db.Decimal(12, 3) @default(0) // limite máximo (opcional)
  updatedAt   DateTime @updatedAt

  @@unique([productId, storeId])
  @@map("stock")
}

// ─────────────────────────────────────────────────────────────
// STOCK MOVEMENTS
// Toda entrada e saída de estoque — imutável (append-only)
// ─────────────────────────────────────────────────────────────

model StockMovement {
  id            String            @id @default(uuid())
  productId     String
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId       String
  store         Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3) // positivo = entrada, negativo = saída
  unitCost      Decimal           @db.Decimal(12, 2) @default(0)
  referenceId   String?           // id do NfeImport, Ticket, etc.
  referenceType String?           // "nfe" | "ticket" | "manual" | "transfer"
  notes         String?
  createdAt     DateTime          @default(now())

  @@index([productId])
  @@index([storeId])
  @@index([referenceId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────
// NFE IMPORTS
// NF-e importadas para dar entrada no estoque
// ─────────────────────────────────────────────────────────────

model NfeImport {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  accessKey    String    @unique // chave de acesso da NF-e (44 dígitos)
  supplierName String
  supplierCnpj String
  totalValue   Decimal   @db.Decimal(12, 2)
  status       NfeStatus @default(PENDING)
  rawXml       String?   @db.Text // XML completo da NF-e
  issuedAt     DateTime
  importedAt   DateTime  @default(now())

  items NfeItem[]

  @@index([tenantId])
  @@index([storeId])
  @@map("nfe_imports")
}

// ─────────────────────────────────────────────────────────────
// NFE ITEMS
// Itens da NF-e linkados a produtos do catálogo
// ─────────────────────────────────────────────────────────────

model NfeItem {
  id          String    @id @default(uuid())
  nfeId       String
  nfe         NfeImport @relation(fields: [nfeId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  productCode String    // código do produto na NF-e (pode ser diferente do SKU interno)
  description String
  ncm         String?   // código NCM
  quantity    Decimal   @db.Decimal(12, 3)
  unitPrice   Decimal   @db.Decimal(12, 4)
  totalPrice  Decimal   @db.Decimal(12, 2)

  @@index([nfeId])
  @@map("nfe_items")
}