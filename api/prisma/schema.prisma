generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
 
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum Plan {
  BASIC
  PRO
  ENTERPRISE
}

enum TicketStatus {
  PENDING
  BOT_ACTIVE
  OPEN
  WAITING
  TRANSFERRED
  RESOLVED
  CLOSED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketChannel {
  WHATSAPP
  EMAIL
  MANUAL
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT_CARD
  SYSTEM
  NOTE
}

enum SenderType {
  CONTACT
  AGENT
  BOT
  SYSTEM
}

enum StockMovementType {
  IN
  OUT
  IN_NFE
  OUT_SALE
  ADJUSTMENT
  TRANSFER
}

enum NfeStatus {
  PENDING
  PROCESSED
  ERROR
  CANCELLED
}

enum BotSessionStatus {
  ACTIVE
  WAITING
  ESCALATED
  FINISHED
  ABANDONED
}

enum N8nTriggerType {
  WEBHOOK
  MESSAGE_RECEIVED
  TICKET_CREATED
  TICKET_CLOSED
  SCHEDULED
}

enum N8nExecutionStatus {
  RUNNING
  SUCCESS
  ERROR
  TIMEOUT
}

enum EvolutionStatus {
  DISCONNECTED
  QR_PENDING
  CONNECTING
  CONNECTED
}

enum TicketEventType {
  CREATED
  BOT_STARTED
  BOT_ESCALATED
  BOT_FINISHED
  ASSUMED
  TRANSFERRED
  RESOLVED
  CLOSED
  REOPENED
  PRIORITY_CHANGED
  TAG_ADDED
  TAG_REMOVED
  NOTE_ADDED
}

// ─────────────────────────────────────────────────────────────
// TENANTS
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(BASIC)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings           TenantSettings?
  users              User[]
  stores             Store[]
  departments        Department[]
  roles              Role[]
  contacts           Contact[]
  evolutionInstances EvolutionInstance[]
  tickets            Ticket[]
  tags               Tag[]
  products           Product[]
  productCategories  ProductCategory[]
  nfeImports         NfeImport[]
  n8nWorkflows       N8nWorkflow[]

  @@map("tenants")
}

model TenantSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  welcomeMessage       String  @default("Olá! Como podemos te ajudar? 😊")
  menuMessage          String  @default("Escolha uma opção:")
  transferMessage      String  @default("Aguarde, estamos transferindo seu atendimento...")
  closingMessage       String  @default("Atendimento encerrado. Obrigado! 😊")
  offlineMessage       String  @default("No momento estamos fora do horário de atendimento.")
  businessHoursEnabled Boolean @default(false)
  businessHoursStart   String  @default("08:00")
  businessHoursEnd     String  @default("18:00")
  businessDays         Int[]   @default([1, 2, 3, 4, 5])
  inactivityTimeout    Int     @default(24)
  maxTicketsPerAgent   Int     @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("tenant_settings")
}

// ─────────────────────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name         String
  email        String
  passwordHash String
  avatarUrl    String?
  isActive     Boolean   @default(true)
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  userRoles      UserRole[]
  tickets        Ticket[]        @relation("AssignedTickets")
  messages       Message[]
  ticketEvents   TicketEvent[]
  stockMovements StockMovement[]
  nfeImports     NfeImport[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// STORES
// ─────────────────────────────────────────────────────────────

model Store {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name      String
  phone     String?
  address   String?
  isActive  Boolean  @default(true)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  departments        Department[]
  evolutionInstances EvolutionInstance[]
  tickets            Ticket[]
  stocks             Stock[]
  stockMovements     StockMovement[]
  nfeImports         NfeImport[]
  userRoles          UserRole[]          // ← campo inverso adicionado

  @@index([tenantId])
  @@map("stores")
}

// ─────────────────────────────────────────────────────────────
// DEPARTMENTS
// ─────────────────────────────────────────────────────────────

model Department {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  name        String
  description String?
  color       String   @default("#6366f1")
  menuOption  Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles UserRole[]  // ← campo inverso adicionado
  tickets   Ticket[]

  @@index([tenantId])
  @@index([storeId])
  @@map("departments")
}

// ─────────────────────────────────────────────────────────────
// RBAC — PERMISSIONS
// ─────────────────────────────────────────────────────────────

model Permission {
  id          String @id @default(uuid())
  key         String @unique
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

// ─────────────────────────────────────────────────────────────
// RBAC — ROLES
// ─────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isSystem    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────
// RBAC — USER_ROLES
// ─────────────────────────────────────────────────────────────

model UserRole {
  id           String      @id @default(uuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  storeId      String?
  store        Store?      @relation(fields: [storeId], references: [id], onDelete: SetNull)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())

  @@unique([userId, roleId, storeId, departmentId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// CONTACTS
// ─────────────────────────────────────────────────────────────

model Contact {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  phone     String
  name      String?
  email     String?
  avatarUrl String?
  isBlocked Boolean  @default(false)
  extraData Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tickets     Ticket[]
  botSessions BotSession[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────
// EVOLUTION INSTANCES
// ─────────────────────────────────────────────────────────────

model EvolutionInstance {
  id          String          @id @default(uuid())
  tenantId    String
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId     String?
  store       Store?          @relation(fields: [storeId], references: [id], onDelete: SetNull)

  instanceName String
  phoneNumber  String?
  apiKey       String
  webhookUrl   String?
  status       EvolutionStatus @default(DISCONNECTED)
  qrCode       String?         @db.Text
  connectedAt  DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tickets      Ticket[]
  botSessions  BotSession[]
  n8nWorkflows N8nWorkflow[]

  @@unique([tenantId, instanceName])
  @@index([tenantId])
  @@map("evolution_instances")
}

// ─────────────────────────────────────────────────────────────
// N8N WORKFLOWS
// ─────────────────────────────────────────────────────────────

model N8nWorkflow {
  id                  String             @id @default(uuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evolutionInstanceId String?
  evolutionInstance   EvolutionInstance? @relation(fields: [evolutionInstanceId], references: [id], onDelete: SetNull)

  n8nWorkflowId String
  name          String
  description   String?
  triggerType   N8nTriggerType @default(MESSAGE_RECEIVED)
  triggerEvent  String?
  isActive      Boolean        @default(true)
  settings      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  botSessions BotSession[]
  executions  N8nExecution[]

  @@unique([tenantId, n8nWorkflowId])
  @@index([tenantId])
  @@map("n8n_workflows")
}

// ─────────────────────────────────────────────────────────────
// BOT SESSIONS
// ─────────────────────────────────────────────────────────────

model BotSession {
  id                  String            @id @default(uuid())
  tenantId            String
  contactId           String
  contact             Contact           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  evolutionInstanceId String
  evolutionInstance   EvolutionInstance @relation(fields: [evolutionInstanceId], references: [id], onDelete: Cascade)
  n8nWorkflowId       String?
  n8nWorkflow         N8nWorkflow?      @relation(fields: [n8nWorkflowId], references: [id], onDelete: SetNull)
  ticketId            String?           @unique
  ticket              Ticket?           @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  status            BotSessionStatus @default(ACTIVE)
  currentStep       String?
  context           Json?
  interactionsCount Int              @default(0)
  startedAt         DateTime         @default(now())
  lastInteractionAt DateTime         @default(now())
  finishedAt        DateTime?

  executions N8nExecution[]

  @@index([tenantId])
  @@index([contactId])
  @@index([evolutionInstanceId])
  @@map("bot_sessions")
}

// ─────────────────────────────────────────────────────────────
// N8N EXECUTIONS
// ─────────────────────────────────────────────────────────────

model N8nExecution {
  id            String             @id @default(uuid())
  n8nWorkflowId String
  n8nWorkflow   N8nWorkflow        @relation(fields: [n8nWorkflowId], references: [id], onDelete: Cascade)
  botSessionId  String?
  botSession    BotSession?        @relation(fields: [botSessionId], references: [id], onDelete: SetNull)
  ticketId      String?

  n8nExecutionId String?
  status         N8nExecutionStatus @default(RUNNING)
  triggerEvent   String?
  inputData      Json?
  outputData     Json?
  errorMessage   String?            @db.Text
  durationMs     Int?
  startedAt      DateTime           @default(now())
  finishedAt     DateTime?

  @@index([n8nWorkflowId])
  @@index([botSessionId])
  @@map("n8n_executions")
}

// ─────────────────────────────────────────────────────────────
// TICKETS
// ─────────────────────────────────────────────────────────────

model Ticket {
  id                  String             @id @default(uuid())
  tenantId            String
  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId             String?
  store               Store?             @relation(fields: [storeId], references: [id], onDelete: SetNull)
  departmentId        String?
  department          Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  contactId           String
  contact             Contact            @relation(fields: [contactId], references: [id])
  assignedTo          String?
  assignedUser        User?              @relation("AssignedTickets", fields: [assignedTo], references: [id], onDelete: SetNull)
  evolutionInstanceId String?
  evolutionInstance   EvolutionInstance? @relation(fields: [evolutionInstanceId], references: [id], onDelete: SetNull)

  protocol      String
  channel       TicketChannel @default(WHATSAPP)
  status        TicketStatus  @default(PENDING)
  priority      Priority      @default(NORMAL)
  subject       String?
  isBotActive   Boolean       @default(false)
  openedAt      DateTime      @default(now())
  closedAt      DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  messages   Message[]
  events     TicketEvent[]
  tags       TicketTag[]
  botSession BotSession?

  @@unique([tenantId, protocol])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, assignedTo])
  @@index([tenantId, departmentId])
  @@map("tickets")
}

// ─────────────────────────────────────────────────────────────
// MESSAGES
// ─────────────────────────────────────────────────────────────

model Message {
  id             String      @id @default(uuid())
  ticketId       String
  ticket         Ticket      @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderUserId   String?
  senderUser     User?       @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  senderType     SenderType  @default(CONTACT)
  content        String?     @db.Text
  type           MessageType @default(TEXT)
  mediaUrl       String?
  mediaName      String?
  evolutionMsgId String?     @unique
  isRead         Boolean     @default(false)
  sentAt         DateTime    @default(now())

  @@index([ticketId])
  @@map("messages")
}

// ─────────────────────────────────────────────────────────────
// TICKET EVENTS
// ─────────────────────────────────────────────────────────────

model TicketEvent {
  id          String          @id @default(uuid())
  ticketId    String
  ticket      Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  type        TicketEventType
  description String?
  changes     Json?
  createdAt   DateTime        @default(now())

  @@index([ticketId])
  @@map("ticket_events")
}

// ─────────────────────────────────────────────────────────────
// TAGS
// ─────────────────────────────────────────────────────────────

model Tag {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name  String
  color String @default("#6366f1")

  ticketTags TicketTag[]

  @@unique([tenantId, name])
  @@map("tags")
}

model TicketTag {
  ticketId String
  tagId    String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([ticketId, tagId])
  @@map("ticket_tags")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT CATEGORIES
// ─────────────────────────────────────────────────────────────

model ProductCategory {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      ProductCategory? @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)

  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  children ProductCategory[] @relation("CategoryChildren")
  products Product[]

  @@index([tenantId])
  @@map("product_categories")
}

// ─────────────────────────────────────────────────────────────
// PRODUCTS
// ─────────────────────────────────────────────────────────────

model Product {
  id         String           @id @default(uuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId String?
  category   ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  sku         String
  name        String
  description String?  @db.Text
  price       Decimal  @db.Decimal(12, 2)
  cost        Decimal  @db.Decimal(12, 2) @default(0)
  unit        String   @default("un")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stocks         Stock[]
  stockMovements StockMovement[]
  nfeItems       NfeItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// STOCK
// ─────────────────────────────────────────────────────────────

model Stock {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  quantity    Decimal  @db.Decimal(12, 3) @default(0)
  minQuantity Decimal  @db.Decimal(12, 3) @default(0)
  maxQuantity Decimal  @db.Decimal(12, 3) @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([productId, storeId])
  @@map("stock")
}

// ─────────────────────────────────────────────────────────────
// STOCK MOVEMENTS
// ─────────────────────────────────────────────────────────────

model StockMovement {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  type          StockMovementType
  quantity      Decimal           @db.Decimal(12, 3)
  unitCost      Decimal           @db.Decimal(12, 2) @default(0)
  referenceId   String?
  referenceType String?
  notes         String?
  createdAt     DateTime          @default(now())

  @@index([productId])
  @@index([storeId])
  @@index([referenceId])
  @@map("stock_movements")
}

// ─────────────────────────────────────────────────────────────
// NFE IMPORTS
// ─────────────────────────────────────────────────────────────

model NfeImport {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId  String
  store    Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  userId   String?
  user     User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  accessKey    String    @unique
  supplierName String
  supplierCnpj String
  totalValue   Decimal   @db.Decimal(12, 2)
  status       NfeStatus @default(PENDING)
  rawXml       String?   @db.Text
  issuedAt     DateTime
  importedAt   DateTime  @default(now())

  items NfeItem[]

  @@index([tenantId])
  @@index([storeId])
  @@map("nfe_imports")
}

// ─────────────────────────────────────────────────────────────
// NFE ITEMS
// ─────────────────────────────────────────────────────────────

model NfeItem {
  id        String    @id @default(uuid())
  nfeId     String
  nfe       NfeImport @relation(fields: [nfeId], references: [id], onDelete: Cascade)
  productId String?
  product   Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  productCode String
  description String
  ncm         String?
  quantity    Decimal @db.Decimal(12, 3)
  unitPrice   Decimal @db.Decimal(12, 4)
  totalPrice  Decimal @db.Decimal(12, 2)

  @@index([nfeId])
  @@map("nfe_items")
}